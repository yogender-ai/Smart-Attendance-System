# SmartFace AI — Environment Variables
# Copy this file to .env and fill in the values

# Flask Secret Key (change this in production!)
SECRET_KEY=your-super-secret-key-change-me

# Database (Neon PostgreSQL)
# Get this from: https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/smartface?sslmode=require

# SMTP Email (Gmail recommended)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Face Data Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FACE_ENCRYPTION_KEY=

# Email Scheduler (24h format)
ABSENTEE_EMAIL_HOUR=18
ABSENTEE_EMAIL_MINUTE=0
